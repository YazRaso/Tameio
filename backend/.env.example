# ── Tameio Contracts – Environment Variables ──────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your deployer wallet private key (without 0x prefix is fine, we handle it)
PRIVATE_KEY=your_private_key_here

# Alchemy RPC endpoint URL for Monad Testnet
# e.g. https://monad-testnet.g.alchemy.com/v2/<api-key>
ALCHEMY_ENDPOINT_URL=https://testnet-rpc.monad.xyz

# Your Alchemy API key (used for contract verification)
ALCHEMY_API_KEY=your_alchemy_api_key_here
